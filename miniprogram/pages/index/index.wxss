/* pages/index/index.wxss */
.user-card {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
}

.user-phone {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8) !important;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.3);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff !important;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8) !important;
}

.device-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.device-item:last-child {
  border-bottom: none;
}

.device-info {
  flex: 1;
}

.device-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.device-location {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.device-actions {
  display: flex;
  align-items: center;
}

.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.log-item:last-child {
  border-bottom: none;
}

.log-info {
  flex: 1;
}

.log-person {
  font-size: 28rpx;
  color: #333;
}

.log-time {
  font-size: 22rpx;
  margin-top: 6rpx;
}

.login-tip {
  padding: 40rpx 0;
  text-align: center;
}
