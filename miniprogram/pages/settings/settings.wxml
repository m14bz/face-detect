<!--pages/settings/settings.wxml-->
<view class="container">
  <!-- 已登录状态 -->
  <view wx:if="{{isLoggedIn}}" class="card">
    <view class="section-title">个人信息</view>
    <view class="user-info-card">
      <view class="user-avatar">👤</view>
      <view class="user-detail">
        <view class="user-name">{{userInfo.name}}</view>
        <view class="user-phone text-muted">{{userInfo.phone}}</view>
        <view class="user-permission">
          <view class="status-tag {{userInfo.permission === 'admin' ? 'status-online' : (userInfo.permission === 'blacklist' ? 'status-offline' : 'status-pending')}}">
            {{userInfo.permission === 'admin' ? '管理员' : (userInfo.permission === 'blacklist' ? '黑名单' : '普通用户')}}
          </view>
        </view>
      </view>
    </view>
    
    <van-button type="danger" block bindtap="logout" custom-style="margin-top: 40rpx;">退出登录</van-button>
  </view>

  <!-- 未登录状态 -->
  <view wx:else class="card">
    <view class="section-title">登录</view>
    <view class="login-form">
      <view class="form-item">
        <text class="form-label">手机号</text>
        <input 
          class="form-input" 
          placeholder="请输入手机号"
          type="number"
          value="{{phone}}"
          bindinput="onInputPhone" />
      </view>
      
      <van-button 
        type="primary" 
        block 
        bindtap="login"
        loading="{{loading}}"
        custom-style="margin-top: 30rpx;">
        登录
      </van-button>
    </view>
  </view>

  <!-- 系统信息 -->
  <view class="card">
    <view class="section-title">关于</view>
    <view class="info-item">
      <text class="text-muted">版本号</text>
      <text>1.0.0</text>
    </view>
    <view class="info-item">
      <text class="text-muted">系统名称</text>
      <text>智慧门禁系统</text>
    </view>
  </view>
</view>
