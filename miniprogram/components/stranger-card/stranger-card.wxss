/* components/stranger-card/stranger-card.wxss */
.stranger-card {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.stranger-card:last-child {
  border-bottom: none;
}

.stranger-image {
  width: 120rpx;
  height: 120rpx;
  margin-right: 20rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.no-image {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  font-size: 40rpx;
}

.stranger-info {
  flex: 1;
}

.stranger-time, .stranger-status, .stranger-processor {
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.stranger-actions {
  display: flex;
  flex-direction: column;
  margin-left: 10rpx;
}
